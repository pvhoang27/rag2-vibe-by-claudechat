# ============================================================
#  RAG Chatbot — Environment Configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME="RAG Chatbot"
APP_VERSION="0.1.0"
APP_ENV="development"           # development | production
DEBUG=true
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR

# --- Server ---
HOST="0.0.0.0"
PORT=8000

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_LLM_MODEL="llama3.2:3b"         # Model dùng để chat (nhẹ, phù hợp máy yếu)
OLLAMA_EMBED_MODEL="nomic-embed-text"  # Model dùng để tạo embedding

# --- ChromaDB (Vector Store) ---
CHROMA_PERSIST_DIR="./data/chroma_db"
CHROMA_COLLECTION_NAME="rag_collection"

# --- RAG Settings ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=3               # Số lượng đoạn văn retrieve
SIMILARITY_THRESHOLD=0.3

# --- Data Paths ---
DATA_RAW_DIR="./data/raw"
DATA_PROCESSED_DIR="./data/processed"

# --- Evaluation ---
EVAL_OUTPUT_DIR="./data/eval_results"
EVAL_SAMPLE_SIZE=10             # Số câu hỏi dùng để evaluate
